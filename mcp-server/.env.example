# Design Space MCP Server — Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Supabase project
DESIGN_SPACE_URL=https://your-project-ref.supabase.co
DESIGN_SPACE_ANON_KEY=your-supabase-anon-key

# Agent identity (set these to auto-register on startup)
AGENT_ID=saga
AGENT_NAME=Saga (Analyst)
AGENT_PLATFORM=claude-code
AGENT_PROJECT=my-project
AGENT_FRAMEWORK=WDS
